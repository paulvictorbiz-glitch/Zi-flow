# ─────────────────────────────────────────────────────────────────────────────
# footagebrain.com — environment template
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored and must NEVER be committed.
# Get the real values from Paul (send via password manager / private DM).
# ─────────────────────────────────────────────────────────────────────────────

# --- REQUIRED: frontend cannot boot without these two ---
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase anon / publishable key>

# Server-side only — bypasses RLS. Used by seed/seed.mjs and Node admin scripts.
# NEVER prefix with VITE_ (that would ship it to the browser bundle).
SUPABASE_SERVICE_ROLE_KEY=<service role key>
OPENROUTER_API_KEY=<openrouter key>

# Non-VITE Supabase URL for server-side API routes (vercel dev / Vercel functions).
SUPABASE_URL=https://<project-ref>.supabase.co

# Resend — sends team account emails from the admin panel. Server-side only.
RESEND_API_KEY=<resend key>
RESEND_FROM=onboarding@resend.dev

# Google Maps — powers the interactive map on the Locations tab.
VITE_GOOGLE_MAPS_API_KEY=<google maps browser key>

# Feedback link shown in the app header (src/app.jsx). Optional — the link
# just hides if unset; the rest of the app is unaffected.
VITE_FEEDBACK_FORM_URL=<google form / typeform url>

# Google Cloud — service account for GCP Monitoring API (monitor tab).
GOOGLE_CLOUD_PROJECT_ID=<gcp project id>
GOOGLE_SERVICE_ACCOUNT_JSON=<single-line service account JSON>

SUGGEST_CRON_SECRET=<cron secret>
IG_SYNC_SECRET=<ig sync secret>

# YouTube playlist auto-ingest -> thumbnail_dna (?action=yt-sync).
YT_THUMBNAIL_PLAYLIST_ID=<public playlist id>

REEL_DECONSTRUCT_SECRET=<reel deconstruct secret>
FB_DOWNLOAD_SIGNING_SECRET=<download signing secret>

# ── MicroSaaS Scout integration (separate Supabase project) ──────────────────
VITE_SCOUT_SUPABASE_URL=https://<scout-project-ref>.supabase.co
VITE_SCOUT_SUPABASE_ANON_KEY=<scout anon key>
SCOUT_BACKEND_URL=https://api.footagebrain.com/scout
# Generate with: openssl rand -hex 32  (must match Hetzner scout-backend/.env)
SCOUT_SCRAPE_SECRET=<scout scrape secret>

PLANABLE_API_TOKEN=<planable token>

# Epidemic Sound — private user session JWT. Expires; refresh when it does.
EPIDEMIC_AUTH_MODE=private
EPIDEMIC_TOKEN=<epidemic jwt>
